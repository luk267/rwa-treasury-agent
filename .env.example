# Sepolia RPC endpoint (e.g. Alchemy, Infura, or a public node).
# Used by Foundry scripts and the TypeScript agent for read/write calls.
RPC_URL_SEPOLIA=

# Deployer / agent EOA private key (hex, no 0x prefix needed for some tools).
# NEVER commit a real key. Use a fresh testnet key for this repo.
PRIVATE_KEY=

# Anthropic API key for the Claude Agent SDK orchestrator.
ANTHROPIC_API_KEY=

# Etherscan API key for contract verification via `forge verify-contract`.
ETHERSCAN_API_KEY=
